{
  "enable_llm_tool": {
    "description": "启用 LLM 工具",
    "hint": "启用后，LLM 可以在对话中自动调用图像生成功能",
    "type": "bool",
    "default": true
  },
  "api": {
    "description": "API 配置",
    "hint": "OpenAI 兼容格式的图片生成接口配置",
    "type": "object",
    "items": {
      "base_url": {
        "description": "API Base URL",
        "hint": "OpenAI 兼容接口地址，留空使用默认地址",
        "type": "string",
        "default": ""
      },
      "api_keys": {
        "description": "API Keys",
        "hint": "支持多个 Key 轮换使用。格式：每行一个 Key",
        "type": "list",
        "default": []
      },
      "model": {
        "description": "模型名称",
        "hint": "例如 gpt-image-2、gpt-image-1",
        "type": "string",
        "default": "gpt-image-2"
      }
    }
  },
  "generation": {
    "description": "生图配置",
    "hint": "图像生成的行为配置",
    "type": "object",
    "items": {
      "max_retry_attempts": {
        "description": "最大重试次数",
        "hint": "生图失败时的重试次数",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 10,
          "step": 1
        },
        "default": 3
      },
      "max_concurrent_tasks": {
        "description": "最大并发任务数",
        "hint": "同时生成图片的最大数量",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 10,
          "step": 1
        },
        "default": 3
      },
      "default_resolution": {
        "description": "默认分辨率",
        "hint": "图片质量等级",
        "type": "string",
        "default": "2K",
        "options": [
          "1K",
          "2K",
          "4K"
        ]
      }
    }
  },
  "user_limits": {
    "description": "用户限制配置",
    "hint": "针对用户的生图频率和数量限制",
    "type": "object",
    "items": {
      "rate_limit_seconds": {
        "description": "速率限制（秒）",
        "hint": "单个用户两次生图请求之间的最小间隔，0 表示不限制",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 60,
          "step": 1
        },
        "default": 0
      },
      "enable_daily_limit": {
        "description": "启用每日生图数量限制",
        "hint": "限制每个用户每天的生图次数",
        "type": "bool",
        "default": false
      },
      "daily_limit_count": {
        "description": "每日生图数量限制",
        "hint": "每个用户每天最多生成的图片数量",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 50,
          "step": 10
        },
        "default": 10
      }
    }
  },
  "presets": {
    "description": "预设提示词",
    "hint": "预定义的图片生成提示词模板。格式: '预设名称:提示词内容'",
    "type": "list",
    "default": [
      "手办化:Your task is to create a photorealistic, masterpiece-quality image of a 1/7 scale commercialized figurine based on the user's character.",
      "绘画四宫格:Step 1: line drawing. Step 2: tile colors. Step 3: Add Shadows. Step 4: Refine and shape. No words",
      "表情包:为我生成图中角色的 Q 版 LINE 风格半身像表情包，4x6 布局，涵盖常用聊天语句"
    ]
  }
}