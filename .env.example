# 这个文件是 test.py 的公开示例配置。
# 真正测试时，请复制成 .env，然后把 Key 改成你自己的 Key。

# openai 表示 OpenAI 兼容接口；gemini 表示 Gemini 官方接口。
API_TYPE=openai

# OpenAI 兼容接口配置。
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-image-2

# Gemini 官方接口配置。把 API_TYPE 改成 gemini 后会读取这两项。
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash-image-preview

RUN_TEXT_TO_IMAGE=true
RUN_IMAGE_TO_IMAGE=false

TEXT_PROMPT=一只白色小猫坐在木桌旁看雨，柔和自然光，照片质感
IMAGE_PROMPT=把参考图改成温暖的插画风头像，保持主体特征

ASPECT_RATIO=1:1
RESOLUTION=1K

# 填一张本地图片路径后会测试图生图；相对路径会按插件目录理解。
REFERENCE_IMAGE=
